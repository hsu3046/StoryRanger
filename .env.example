# Story Ranger — environment variables
# Copy this file to .env.local (never commit .env.local).

# ════════════════════════════════════════════════════════════
# LLM PROVIDER  (companion dialogue uses this)
# ════════════════════════════════════════════════════════════

# Which provider to use for dialogue LLM calls.
#   openai     — OpenAI gpt-5* family (default)
#   gemini     — Google Gemini
#   anthropic  — Anthropic Claude
#   openrouter — OpenRouter (one key → many models, OpenAI-compatible)
LLM_PROVIDER=openai

# Optional ordered fallback chain (comma list) used when the active provider
# fails after retries. Only providers WITH a key are tried, so it's a safe
# no-op until you add a second key. Leave empty to auto-use the others.
# Example: LLM_FALLBACK=openrouter,gemini
LLM_FALLBACK=

# Specific model name. Leave empty to use the provider's default.
# Provider defaults:
#   openai     → gpt-5-mini
#   gemini     → gemini-3-flash-preview
#   anthropic  → claude-sonnet-4-6
# Examples:
#   gpt-5            (openai — better prose, ~5× cost)
#   gpt-5.5          (openai — best prose, slowest)
#   gemini-3-pro     (gemini — higher quality)
#   gemini-3-flash-preview  (gemini — fast, cheap, default)
#   claude-opus-4-7  (anthropic — top quality)
LLM_MODEL=

# ════════════════════════════════════════════════════════════
# API KEYS  (only the key for the chosen LLM_PROVIDER is required)
# ════════════════════════════════════════════════════════════

# OpenAI — drives the LLM when LLM_PROVIDER=openai. (TTS is ElevenLabs now,
# see below — OPENAI_API_KEY is no longer used for voice.)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — required when LLM_PROVIDER=gemini.
# https://aistudio.google.com/apikey
# (GOOGLE_API_KEY is also accepted as a fallback name.)
GEMINI_API_KEY=

# Anthropic — required when LLM_PROVIDER=anthropic.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter — one key, many models (OpenAI-compatible). Required when
# LLM_PROVIDER=openrouter (or when openrouter is in LLM_FALLBACK).
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model id (provider/model). Default: openai/gpt-5-mini. The model MUST support
# structured outputs (json_schema). Examples:
#   google/gemini-3-flash · anthropic/claude-sonnet-4.6 · deepseek/deepseek-v4
OPENROUTER_MODEL=
# Optional attribution headers shown on OpenRouter rankings (both optional).
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# ════════════════════════════════════════════════════════════
# AI IMAGE GENERATION  (Nano Banana — admin Story Generator, dev only)
# ════════════════════════════════════════════════════════════

# The admin "Generate Story" wizard generates cover / scene / character images
# with a Gemini image model. It reuses GEMINI_API_KEY (or GOOGLE_API_KEY) above
# — no separate key needed.
#
# Model to use. Leave empty for the default (Nano Banana 2).
#   gemini-3.1-flash-image  — Nano Banana 2 (default; fast, ~$0.06-0.13/image)
#   gemini-3-pro-image      — Nano Banana Pro (higher quality, pricier)
IMAGE_MODEL=

# ════════════════════════════════════════════════════════════
# TTS  (ElevenLabs) — narration + character speech
# ════════════════════════════════════════════════════════════

# ElevenLabs API key (Creator plan). Dashboard → Profile → API Keys.
# Without it, /api/tts returns 503 and narration is silent (no crash).
ELEVENLABS_API_KEY=

# Model is fixed in code (eleven_multilingual_v2). Voices are per-character —
# set each in admin → Characters → "Voice" to an ElevenLabs voice id.
# Generated audio is cached on-demand to R2 (reuses the R2_* vars below) and
# served from NEXT_PUBLIC_ASSET_BASE_URL.

# ════════════════════════════════════════════════════════════
# STATIC ASSETS  (images + audio)
# ════════════════════════════════════════════════════════════

# Where the browser loads images + audio from. NO trailing slash. Public
# (client) var, inlined at build time.
#
# LOCAL DEV: leave EMPTY — assets serve same-origin from public/ (instant).
#   Do NOT point local dev at r2.dev: it is rate-limited and NOT served from
#   Cloudflare's CDN cache, so every asset is a ~1s-TTFB origin fetch.
# PRODUCTION: set to a **custom domain** mapped to the R2 bucket
#   (e.g. https://assets.yourdomain.com) — that routes through the CDN (cached,
#   fast). The pub-*.r2.dev URL works but is meant only for quick testing.
NEXT_PUBLIC_ASSET_BASE_URL=

# ── R2 upload (used ONLY by scripts/sync-r2.sh — never shipped to client) ──
# From Cloudflare dashboard → R2 → Manage R2 API Tokens (S3 credentials).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storyranger-assets
