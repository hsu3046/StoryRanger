# Story Ranger — environment variables
# Copy this file to .env.local (never commit .env.local).

# ════════════════════════════════════════════════════════════
# LLM PROVIDER  (companion dialogue uses this)
# ════════════════════════════════════════════════════════════

# Which provider to use for dialogue LLM calls.
#   openai     — OpenAI gpt-5* family (default)
#   gemini     — Google Gemini
#   anthropic  — Anthropic Claude
LLM_PROVIDER=openai

# Specific model name. Leave empty to use the provider's default.
# Provider defaults:
#   openai     → gpt-5-mini
#   gemini     → gemini-3-flash-preview
#   anthropic  → claude-sonnet-4-6
# Examples:
#   gpt-5            (openai — better prose, ~5× cost)
#   gpt-5.5          (openai — best prose, slowest)
#   gemini-3-pro     (gemini — higher quality)
#   gemini-3-flash-preview  (gemini — fast, cheap, default)
#   claude-opus-4-7  (anthropic — top quality)
LLM_MODEL=

# ════════════════════════════════════════════════════════════
# API KEYS  (only the key for the chosen LLM_PROVIDER is required;
#            OPENAI_API_KEY is ALSO required for TTS regardless)
# ════════════════════════════════════════════════════════════

# OpenAI — required for TTS (character voice playback). Also drives
# the LLM when LLM_PROVIDER=openai.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — required when LLM_PROVIDER=gemini.
# https://aistudio.google.com/apikey
# (GOOGLE_API_KEY is also accepted as a fallback name.)
GEMINI_API_KEY=

# Anthropic — required when LLM_PROVIDER=anthropic.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ════════════════════════════════════════════════════════════
# TTS  (ElevenLabs) — narration + character speech
# ════════════════════════════════════════════════════════════

# ElevenLabs API key (Creator plan). Dashboard → Profile → API Keys.
# Without it, /api/tts returns 503 and narration is silent (no crash).
ELEVENLABS_API_KEY=

# Model is fixed in code (eleven_multilingual_v2). Voices are per-character —
# set each in admin → Characters → "Voice" to an ElevenLabs voice id.
# Generated audio is cached on-demand to R2 (reuses the R2_* vars below) and
# served from NEXT_PUBLIC_ASSET_BASE_URL.

# ════════════════════════════════════════════════════════════
# STATIC ASSETS  (images + audio)
# ════════════════════════════════════════════════════════════

# Where the browser loads images + audio from. Leave EMPTY to serve same-origin
# from public/ (default, dev). Set to a CDN origin — a Cloudflare R2 bucket's
# r2.dev URL (dev) or a custom domain (prod) — to serve media from there.
# NO trailing slash. Public (client) var, so it's inlined at build time.
#   e.g. https://pub-xxxxxxxx.r2.dev   or   https://assets.yourdomain.com
NEXT_PUBLIC_ASSET_BASE_URL=

# ── R2 upload (used ONLY by scripts/sync-r2.sh — never shipped to client) ──
# From Cloudflare dashboard → R2 → Manage R2 API Tokens (S3 credentials).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storyranger-assets
